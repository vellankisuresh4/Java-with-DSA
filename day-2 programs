👍#code for to find the factorial for given range.
 import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();

        if (a < 0) {
            System.out.println("We cannot find the factorial");
        } else {
            for (int n = 1; n <= a; n++) {
                int fact = 1;

                for (int i = 1; i <= n; i++) {
                    fact = fact * i;
                }

                System.out.println("Factorial of " + n + " = " + fact);
            }
        }

        sc.close();
    }
}

👍prime or not
import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        boolean isPrime = true;

        if (n <= 1) {
            isPrime = false;
        } else {
            for (int i = 2; i < n; i++) {
                if (n % i == 0) {
                    isPrime = false;
                    break;
                }
            }
        }

        if (isPrime)
            System.out.println(n + " is Prime");
        else
            System.out.println(n + " is Not Prime");
    }
}

